      top: 50%;
      transform: translateY(-50%);
      z-index: 1;
      animation: floatIceCream 6s ease-in-out infinite;
    }

    @keyframes floatIceCream {
      0% { transform: translateY(-50%) scale(1) rotate(-2deg); }
      50% { transform: translateY(-60%) scale(1.05) rotate(2deg); }
      100% { transform: translateY(-50%) scale(1) rotate(-2deg); }
    }

    .icecream-scoop {
      animation: wobbleScoop 3s ease-in-out infinite;
      transform-origin: center bottom;
    }

    @keyframes wobbleScoop {
      0%, 100% { transform: rotate(-3deg) scale(1); }
      50% { transform: rotate(3deg) scale(1.02); }
    }

