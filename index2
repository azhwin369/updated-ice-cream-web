      animation: dripMove 4s ease-in-out infinite;
    }

    @keyframes dripMove {
      0%, 100% { transform: translateY(0) scale(1); opacity: 0.9; }
      50% { transform: translateY(4px) scale(0.95); opacity: 0.6; }
    }

    .icecream-sparkle {
      animation: sparkle 2.5s ease-in-out infinite;
    }

    @keyframes sparkle {
      0%, 100% { opacity: 1; transform: scale(1) rotate(0deg); }
      50% { opacity: 0.3; transform: scale(1.3) rotate(20deg); }
    }

    .icecream-sparkle-2 {
      animation: sparkle 3s ease-in-out infinite 0.8s;
    }

    .cherry {
      animation: bounceCherry 2.5s ease-in-out infinite;
      transform-origin: center;
    }

    @keyframes bounceCherry {
      0%, 100% { transform: scale(1) rotate(0deg); }
      30% { transform: scale(1.15) rotate(-8deg); }
      60% { transform: scale(1.05) rotate(5deg); }
    }

    .sprinkle {
      animation: sprinkleFloat 5s ease-in-out infinite;
    }
    .sprinkle:nth-child(1) { animation-delay: 0s; }
    .sprinkle:nth-child(2) { animation-delay: 1.2s; }
    .sprinkle:nth-child(3) { animation-delay: 2.5s; }

    @keyframes sprinkleFloat {
      0%, 100% { transform: translateY(0) rotate(0deg) scale(1); }
      50% { transform: translateY(-15px) rotate(180deg) scale(0.8); }
    }

