  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Inter', sans-serif;
      background: #0d0b0a;
      color: #e8e0d8;
      line-height: 1.5;
      scroll-behavior: smooth;
      overflow-x: hidden;
    }

    h1, h2, h3, .logo, .nav-links a, .page-title { font-family: 'Playfair Display', serif; }

    .container { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }

    nav {
      position: sticky;
      top: 0;
      z-index: 999;
      padding: 0.8rem 2rem;
      background: rgba(13, 11, 10, 0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(212, 175, 55, 0.15);
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
    }
    .logo { font-size: 1.8rem; font-weight: 700; color: #e8e0d8; letter-spacing: -0.5px; }
    .logo i { color: #d4af37; margin-right: 6px; }
    .nav-links { display: flex; gap: 2.2rem; font-weight: 500; list-style: none; }
    .nav-links a {
      text-decoration: none;
      color: #c8c0b8;
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem;
      transition: 0.3s ease;
      border-bottom: 2px solid transparent;
      padding-bottom: 4px;
      letter-spacing: 0.5px;
    }
    .nav-links a:hover, .nav-links a.active { border-bottom-color: #d4af37; color: #d4af37; }

    /* ===== MENU HERO ===== */
    .menu-hero {
      padding: 6rem 2rem 3rem;
      text-align: center;
      position: relative;
      background: linear-gradient(145deg, #0d0b0a 0%, #1a1512 100%);
      overflow: hidden;
    }
    .menu-hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at 20% 30%, rgba(212, 175, 55, 0.04) 0%, transparent 60%),
        radial-gradient(ellipse at 80% 70%, rgba(212, 175, 55, 0.03) 0%, transparent 60%);
      pointer-events: none;
    }
    .menu-hero .eyebrow {
      display: inline-block;
      color: #d4af37;
      font-size: 0.85rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      margin-bottom: 1rem;
      opacity: 0;
      animation: fadeUp 0.8s ease-out forwards;
    }
    .page-title {
      font-size: clamp(2.6rem, 8vw, 4.2rem);
      font-weight: 700;
      color: #e8e0d8;
      position: relative;
      z-index: 1;
      opacity: 0;
      animation: fadeUp 0.9s ease-out 0.1s forwards;
    }
    .page-title span {
      background: linear-gradient(135deg, #d4af37, #f0d060, #d4af37);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      background-size: 200% 200%;
      animation: goldShine 4s ease-in-out infinite;
    }
    @keyframes goldShine { 0%,100%{background-position:0% 50%;} 50%{background-position:100% 50%;} }
    .menu-hero p {
      max-width: 520px;
      margin: 1rem auto 0;
      color: #a89888;
      font-weight: 300;
      font-size: 1.05rem;
      position: relative;
      z-index: 1;
      opacity: 0;
      animation: fadeUp 0.9s ease-out 0.2s forwards;
    }
    @keyframes fadeUp { 0%{opacity:0;transform:translateY(20px);} 100%{opacity:1;transform:translateY(0);} }

    /* ===== CATEGORY NAV ===== */
    .category-nav {
      position: sticky;
      top: 63px;
      z-index: 900;
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.8rem;
      padding: 1rem 1.2rem;
      background: rgba(13, 11, 10, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(212, 175, 55, 0.08);
      margin-bottom: 1rem;
    }
    .category-nav a {
      text-decoration: none;
      color: #a89888;
      font-size: 0.85rem;
      letter-spacing: 0.5px;
      padding: 0.5rem 1.2rem;
      border-radius: 60px;
      border: 1px solid rgba(212, 175, 55, 0.12);
      transition: 0.3s ease;
      white-space: nowrap;
    }
    .category-nav a:hover, .category-nav a:focus-visible {
      color: #0d0b0a;
      background: #d4af37;
      border-color: #d4af37;
    }

    /* ===== MENU SECTIONS ===== */
    .menu-section { padding: 3.5rem 0 1rem; scroll-margin-top: 130px; }
    .section-head { display: flex; align-items: baseline; gap: 1rem; margin-bottom: 2rem; }
    .section-head i { color: #d4af37; font-size: 1.6rem; }
    .section-title {
      font-size: 2.2rem;
      font-weight: 600;
      color: #e8e0d8;
      position: relative;
    }
    .section-title::after {
      content: '';
      position: absolute;
      bottom: -8px;
      left: 0;
      width: 50px;
      height: 3px;
      background: linear-gradient(90deg, #d4af37, transparent);
    }
    .section-note { color: #8a7a6a; font-weight: 300; font-size: 0.95rem; margin-left: auto; }

    .menu-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.4rem;
      margin-bottom: 1rem;
    }

    .menu-item {
      display: flex;
      gap: 1.1rem;
      align-items: center;
      padding: 1.1rem;
      background: rgba(20, 17, 15, 0.6);
      backdrop-filter: blur(4px);
      border-radius: 1.6rem;
      border: 1px solid rgba(212, 175, 55, 0.07);
      transition: all 0.3s ease;
    }
    .menu-item:hover {
      background: rgba(30, 25, 22, 0.9);
      border-color: rgba(212, 175, 55, 0.22);
      transform: translateY(-4px);
    }
    .menu-item img {
      width: 76px;
      height: 76px;
      border-radius: 1.2rem;
      object-fit: cover;
      flex-shrink: 0;
      background: #1a1614;
      border: 1px solid rgba(212, 175, 55, 0.08);
    }
    .item-info { flex: 1; min-width: 0; }
    .item-top { display: flex; justify-content: space-between; align-items: baseline; gap: 0.6rem; flex-wrap: wrap; }
    .item-top h4 {
      font-family: 'Playfair Display', serif;
      font-weight: 600;
      color: #e8e0d8;
      font-size: 1.08rem;
    }
    .item-price { color: #d4af37; font-weight: 600; font-size: 1.02rem; white-space: nowrap; }
    .item-info p { color: #8a7a6a; font-size: 0.86rem; font-weight: 300; margin-top: 0.25rem; }
    .item-tags { margin-top: 0.5rem; display: flex; gap: 0.4rem; flex-wrap: wrap; }
    .tag {
      font-size: 0.68rem;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      color: #d4af37;
      border: 1px solid rgba(212, 175, 55, 0.25);
      padding: 0.15rem 0.55rem;
      border-radius: 60px;
    }

    /* Buy Now button (menu version) */
    .btn-buy-menu {
      display: inline-block;
      padding: 0.35rem 1rem;
      border-radius: 60px;
      font-weight: 600;
      text-decoration: none;
      transition: 0.3s ease;
      border: none;
      font-size: 0.75rem;
      letter-spacing: 0.3px;
      cursor: pointer;
      background: linear-gradient(135deg, #d4af37, #b8941e);
      color: #0d0b0a;
      margin-top: 0.4rem;
      box-shadow: 0 4px 15px -4px rgba(212, 175, 55, 0.2);
    }
    .btn-buy-menu:hover {
      transform: translateY(-2px) scale(1.05);
      box-shadow: 0 8px 25px -4px rgba(212, 175, 55, 0.4);
      background: linear-gradient(135deg, #e0c040, #d4af37);
    }

    /* ===== BUILD YOUR OWN ===== */
    .build-banner {
      background: linear-gradient(135deg, rgba(212, 175, 55, 0.06), rgba(212, 175, 55, 0.01));
      border-radius: 3rem;
      padding: 3rem 2.5rem;
      margin: 3.5rem 0;
      border: 1px solid rgba(212, 175, 55, 0.12);
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .build-banner::before {
      content: '';
      position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
      background: radial-gradient(circle at center, rgba(212, 175, 55, 0.02), transparent 70%);
      animation: rotateGlow 20s linear infinite;
    }
    @keyframes rotateGlow { 0%{transform:rotate(0deg);} 100%{transform:rotate(360deg);} }
    .build-banner h2 { font-size: 2rem; color: #e8e0d8; position: relative; z-index: 1; }
    .build-banner p { color: #8a7a6a; position: relative; z-index: 1; max-width: 480px; margin: 0.6rem auto 0; }
    .build-steps {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 2rem;
      margin-top: 1.8rem;
      position: relative;
      z-index: 1;
    }
    .build-step { max-width: 160px; }
    .build-step .num {
      font-family: 'Playfair Display', serif;
      color: #d4af37;
      font-size: 1.4rem;
      font-weight: 700;
    }
    .build-step p { color: #c8c0b8; font-size: 0.85rem; margin-top: 0.3rem; }
    .build-banner .btn { margin-top: 1.6rem; position: relative; z-index: 1; }
    .btn {
      display: inline-block;
      padding: 0.9rem 2.4rem;
      border-radius: 60px;
      font-weight: 600;
      text-decoration: none;
      transition: 0.3s ease;
      border: none;
      font-size: 1rem;
      letter-spacing: 0.5px;
      cursor: pointer;
      background: linear-gradient(135deg, #d4af37, #b8941e);
      color: #0d0b0a;
      box-shadow: 0 8px 30px -8px rgba(212, 175, 55, 0.3);
    }
    .btn:hover {
      transform: translateY(-2px) scale(1.02);
      box-shadow: 0 12px 40px -8px rgba(212, 175, 55, 0.5);
      background: linear-gradient(135deg, #e0c040, #d4af37);
    }

    /* ===== ALLERGEN NOTE ===== */
    .allergen-note {
      display: flex;
      gap: 0.8rem;
      align-items: flex-start;
      padding: 1.4rem 1.6rem;
      background: rgba(20, 17, 15, 0.5);
      border-radius: 1.6rem;
      border: 1px solid rgba(212, 175, 55, 0.06);
      margin: 2rem 0 4rem;
    }
    .allergen-note i { color: #d4af37; font-size: 1.2rem; margin-top: 0.15rem; }
    .allergen-note p { color: #8a7a6a; font-size: 0.88rem; font-weight: 300; }

    footer {
      margin-top: 2rem;
      padding: 2.5rem 0 1.5rem;
      border-top: 1px solid rgba(212, 175, 55, 0.06);
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 2rem;
    }
    .footer-links a { margin: 0 1rem 0 0; color: #8a7a6a; text-decoration: none; transition: 0.3s ease; font-weight: 300; }
    .footer-links a:hover { color: #d4af37; }
    .footer-links span { color: #4a3a2a; }
    .social i { font-size: 1.6rem; margin-left: 1rem; color: #5a4a3a; transition: 0.3s ease; }
    .social i:hover { color: #d4af37; transform: scale(1.1); }

    .back-to-top {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      background: rgba(212, 175, 55, 0.12);
      backdrop-filter: blur(8px);
      padding: 0.8rem 1.1rem;
      border-radius: 60px;
      color: #d4af37;
      font-size: 1.4rem;
      border: 1px solid rgba(212, 175, 55, 0.1);
      transition: 0.3s ease;
      text-decoration: none;
    }
    .back-to-top:hover {
      background: rgba(212, 175, 55, 0.2);
      transform: scale(1.05);
      color: #f0d060;
      box-shadow: 0 8px 30px rgba(212, 175, 55, 0.05);
    }

    @media (max-width: 700px) {
      .nav-links { gap: 1rem; }
      .container { padding: 0 1.2rem; }
      .section-note { margin-left: 0; }
      .section-head { flex-wrap: wrap; }
      .build-banner { padding: 2rem 1.2rem; }
    }
  </style>
</head>
